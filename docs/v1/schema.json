{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JSON Range Index v1",
  "description": "Sidecar index for partially loading large JSON documents via ranged GET.",
  "type": "object",
  "required": ["$schema", "root"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "const": "https://brian14708.github.io/jrif/v1/schema.json"
    },
    "root": {
      "$ref": "#/$defs/Node"
    }
  },
  "$defs": {
    "Range": {
      "type": "array",
      "prefixItems": [
        {
          "type": "integer",
          "minimum": 0,
          "description": "start byte offset (inclusive)"
        },
        {
          "type": "integer",
          "minimum": 0,
          "description": "end byte offset (inclusive)"
        }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "Checksum": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$",
      "description": "Lowercase hexadecimal xxh3-128 digest."
    },
    "Node": {
      "oneOf": [
        {
          "$ref": "#/$defs/ScalarNode"
        },
        {
          "$ref": "#/$defs/ArrayNode"
        },
        {
          "$ref": "#/$defs/ObjectNode"
        }
      ]
    },
    "NodeCommon": {
      "type": "object",
      "required": ["range", "checksum"],
      "properties": {
        "range": {
          "$ref": "#/$defs/Range"
        },
        "checksum": {
          "$ref": "#/$defs/Checksum"
        }
      }
    },
    "ScalarNode": {
      "allOf": [
        {
          "$ref": "#/$defs/NodeCommon"
        }
      ],
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["null", "boolean", "number", "string"]
        }
      },
      "unevaluatedProperties": false
    },
    "ArrayNode": {
      "allOf": [
        {
          "$ref": "#/$defs/NodeCommon"
        }
      ],
      "required": ["type"],
      "properties": {
        "type": {
          "const": "array"
        },
        "field_table": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Shared field name table for arrays of structs."
        },
        "chunks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ArrayChunk"
          }
        }
      },
      "unevaluatedProperties": false
    },
    "ObjectNode": {
      "allOf": [
        {
          "$ref": "#/$defs/NodeCommon"
        }
      ],
      "required": ["type"],
      "properties": {
        "type": {
          "const": "object"
        },
        "chunks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ObjectChunk"
          }
        }
      },
      "unevaluatedProperties": false
    },
    "ArrayChunk": {
      "oneOf": [
        {
          "$ref": "#/$defs/ItemsChunk"
        },
        {
          "$ref": "#/$defs/ItemChunk"
        }
      ]
    },
    "ObjectChunk": {
      "oneOf": [
        {
          "$ref": "#/$defs/FieldsChunk"
        },
        {
          "$ref": "#/$defs/FieldChunk"
        }
      ]
    },
    "ItemsChunk": {
      "type": "object",
      "required": ["kind", "items", "range", "checksum"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "items"
        },
        "items": {
          "type": "array",
          "prefixItems": [
            {
              "type": "integer",
              "minimum": 0,
              "description": "first_ordinal (inclusive)"
            },
            {
              "type": "integer",
              "minimum": 0,
              "description": "last_ordinal (inclusive)"
            }
          ],
          "minItems": 2,
          "maxItems": 2
        },
        "range": {
          "$ref": "#/$defs/Range"
        },
        "checksum": {
          "$ref": "#/$defs/Checksum"
        }
      }
    },
    "ItemChunk": {
      "type": "object",
      "required": ["kind", "ordinal", "range", "checksum"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "item"
        },
        "ordinal": {
          "type": "integer",
          "minimum": 0
        },
        "range": {
          "$ref": "#/$defs/Range"
        },
        "checksum": {
          "$ref": "#/$defs/Checksum"
        },
        "chunks": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/ArrayChunk"
              },
              {
                "$ref": "#/$defs/ObjectChunk"
              }
            ]
          },
          "description": "ObjectChunk[] when item is an object; ArrayChunk[] when item is an array. Absent for primitives."
        }
      }
    },
    "FieldsChunk": {
      "type": "object",
      "required": ["kind", "fields", "range", "checksum"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "fields"
        },
        "fields": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 0
              },
              "minItems": 1
            }
          ],
          "description": "Field names or field_table indexes. Must not mix strings and integers."
        },
        "range": {
          "$ref": "#/$defs/Range"
        },
        "checksum": {
          "$ref": "#/$defs/Checksum"
        }
      }
    },
    "FieldChunk": {
      "type": "object",
      "required": ["kind", "name", "range", "checksum"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "field"
        },
        "name": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "integer",
              "minimum": 0
            }
          ],
          "description": "Field name or field_table index."
        },
        "range": {
          "$ref": "#/$defs/Range"
        },
        "checksum": {
          "$ref": "#/$defs/Checksum"
        },
        "chunks": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/ArrayChunk"
              },
              {
                "$ref": "#/$defs/ObjectChunk"
              }
            ]
          },
          "description": "Nested chunks when the field value is an array or object. Absent for primitives."
        }
      }
    }
  }
}
